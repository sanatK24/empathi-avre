# API endpoint for the backend
VITE_API_BASE_URL=http://localhost:8000

# Google OAuth client ID used by the sign-in flow
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# OpenAI API Key for AI campaign enhancement and urgency analysis
VITE_OPENAI_API_KEY=sk_your_key_here

# NewsAPI Key for crisis signal detection and emergency news monitoring
VITE_NEWS_API_KEY=your_key_here

# Google Maps API Key for geocoding and location services
VITE_GOOGLE_MAPS_API_KEY=your_key_here
