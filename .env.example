# --- DATABASE CONFIG ---
POSTGRES_USER=empathi_user
POSTGRES_PASSWORD=empathi_password
POSTGRES_DB=empathi_db
DB_HOST=db
DB_PORT=5432

# SQLAlchemy URL for Backend
DATABASE_URL=postgresql://empathi_user:empathi_password@db:5432/empathi_db

# --- REAL-TIME CONFIG ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
ENABLE_RABBITMQ=True

# --- BACKEND CONFIG ---
SECRET_KEY=DEVELOPMENT_ONLY_INSECURE_KEY_REPLACE_ME_IN_PRODUCTION
DEBUG=True
APP_NAME=EmpathI

# ML Settings
MODEL_PATH=ml/model.pkl

# --- FRONTEND CONFIG ---
VITE_API_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
