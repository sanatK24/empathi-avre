# Backend Configuration - Copy to .env and fill in actual values
# === Authentication & Security ===
SECRET_KEY=your-super-secret-key-min-32-chars-in-production
ALGORITHM=HS256

# === CORS Configuration ===
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# === Database ===
DATABASE_URL=sqlite:///./avre.db
# For PostgreSQL: postgresql://user:password@localhost:5432/avre_db

# === Logging ===
LOG_LEVEL=INFO

# === ML Model Path ===
ML_MODEL_PATH=backend/ml/model.pkl

# === Server ===
HOST=0.0.0.0
PORT=8000
RELOAD=true
